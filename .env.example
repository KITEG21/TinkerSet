# Environment Variables Template

# Copy this file to `.env` in the application directory and customize values.
#
# Windows Installer:
#   C:\Program Files\TinkerSet\.env
#
# Portable ZIP:
#   [extracted_folder]\.env

# ======================
# LLM Provider Selection
# ======================
# Choose: ollama, grok, groq, openai
AFM_LLM_PROVIDER=ollama

# ==============
# Ollama (Local)
# ==============
# Recommended for privacy and cost (runs locally)
AFM_OLLAMA_BASE_URL=http://127.0.0.1:11434
AFM_OLLAMA_MODEL=llama3.2

# ===============
# Grok API (Cloud)
# ===============
# AFM_LLM_PROVIDER=grok
# AFM_GROK_API_KEY=xai-xxxxxxxxxxxx
# AFM_GROK_BASE_URL=https://api.x.ai/v1
# AFM_GROK_MODEL=grok-2-latest

# =================
# Groq API (Cloud)
# =================
# AFM_LLM_PROVIDER=groq
# AFM_GROQ_API_KEY=gsk_xxxxxxxxxxxx
# AFM_GROQ_BASE_URL=https://api.groq.com/openai/v1
# AFM_GROQ_MODEL=llama-3.3-70b-versatile

# ==================
# OpenAI API (Cloud)
# ==================
# AFM_LLM_PROVIDER=openai
# AFM_OPENAI_API_KEY=sk-xxxxxxxxxxxx
# AFM_OPENAI_MODEL=gpt-4-turbo

# ==============
# UI / Display
# ==============
# Show Python backend console window (1 = yes, 0 = no)
AFM_SHOW_PY_CONSOLE=1

# ==============
# API Server
# ==============
AFM_API_HOST=127.0.0.1
AFM_API_PORT=8000

# ==============
# Logging
# ==============
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
AFM_LOG_LEVEL=INFO
# Optional log file path
# AFM_LOG_FILE=C:\temp\tinkerset.log

# =======================
# File Operation Settings
# =======================
# Check disk space before operations (1 = on, 0 = off)
AFM_CHECK_DISK_SPACE=1

# Skip existing files at destination (1 = skip, 0 = overwrite)
AFM_SKIP_EXISTING=0

# Max files processed per operation
AFM_MAX_FILES=10000

# Operation timeout in seconds
AFM_OPERATION_TIMEOUT=60

# =======================
# Development / Advanced
# =======================
# VITE_PORT=5173
# VITE_API_URL=http://127.0.0.1:8000
